# Defina "true" para ativar auth e APIs Supabase. Omitido ou != true = inativo (sem middleware/auth).
# NEXT_PUBLIC_SUPABASE_ENABLED=true

# Cadastro em /signup em produção (padrão: desligado). Só em dev local sem esta var segue o Supabase acima.
# NEXT_PUBLIC_SIGNUP_ENABLED=true

# Supabase (projeto em https://supabase.com — Authentication > Providers > Email)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role: APENAS servidor (API /api/auth/signup). Nunca expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Link do convite do grupo WhatsApp (obrigatório em produção)
NEXT_PUBLIC_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/G2VXJ9UManZ77Rx7Uzn7NT
